<view class="container">
  <image class="background-image" src="/images/小程序背景.jpeg" mode="aspectFill"></image>
  
  <view class="user-section">
    <view class="user-header">
      <block wx:if="{{hasUserInfo}}">
        <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="user-info">
          <text class="user-name">{{userInfo.nickName}}</text>
          <view class="user-role" wx:if="{{isAdmin}}">
            <text class="role-tag admin">管理员</text>
          </view>
          <view class="user-role" wx:else>
            <text class="role-tag user">普通用户</text>
          </view>
        </view>
      </block>
      <block wx:else>
        <image class="user-avatar" src="/images/default-avatar.png" mode="aspectFill"></image>
        <view class="user-info">
          <text class="user-name">未登录</text>
          <text class="user-welcome">点击下方按钮登录</text>
        </view>
      </block>
    </view>
    
    <block wx:if="{{!hasUserInfo}}">
      <button class="auth-btn" bindtap="login" loading="{{isLoading}}">
        {{isLoading ? '登录中...' : '微信授权登录'}}
      </button>
    </block>
    
    <block wx:else>
      <button class="logout-btn" bindtap="logout">
        退出登录
      </button>
    </block>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToMyBookings">
      <view class="menu-left">
        <text class="menu-icon-text">📋</text>
        <text class="menu-text">我的预约</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    
    <view class="menu-item {{isAdmin ? '' : 'disabled'}}" bindtap="goToAdmin">
      <view class="menu-left">
        <text class="menu-icon-text">⚙️</text>
        <text class="menu-text">管理后台</text>
        <text class="admin-badge" wx:if="{{isAdmin}}">管理员</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="info-section">
    <view class="info-card">
      <view class="info-title">使用说明</view>
      <view class="info-content">
        <text>1. 点击"预订"页面进行参观预约</text>
        <text>2. 在"我的预约"查看预约状态</text>
        <text>3. 管理员可进入后台管理预约</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">技术支持：广东药科大学医药信息工程学院</text>
    <text class="footer-text">广东药科大学青莲社</text>
  </view>
</view>
