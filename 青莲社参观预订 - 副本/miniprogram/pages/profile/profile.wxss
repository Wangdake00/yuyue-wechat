/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  position: relative;
  padding: 0;
  padding-bottom: 40rpx;
}

.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  opacity: 0.15;
}

.user-section {
  background: white;
  padding: 60rpx 40rpx 40rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  text-align: center;
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  justify-content: center;
  flex-direction: column;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-bottom: 25rpx;
  border: 4rpx solid #07C160;
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.2);
}

.user-info {
  flex: 1;
  text-align: center;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.user-welcome {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.user-role {
  margin-top: 10rpx;
}

.role-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.role-tag.admin {
  background: linear-gradient(135deg, #ff6b6b, #ee5a5a);
  color: white;
}

.role-tag.user {
  background: #f0f0f0;
  color: #666;
}

.logout-btn {
  margin-top: 15rpx;
  padding: 15rpx 40rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 26rpx;
  border-radius: 30rpx;
  border: none;
  display: inline-block;
  font-weight: 500;
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  background: #e8e8e8;
}

.auth-btn {
  background: #07C160;
  color: white;
  padding: 25rpx 40rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  border: none;
  width: 100%;
  max-width: 400rpx;
  margin: 0 auto;
  display: block;
  font-weight: 500;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.3);
}

.auth-btn:active {
  background: #06a850;
}

.menu-section {
  background: white;
  margin: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 35rpx 40rpx;
  border-bottom: 1rpx solid #f8f8f8;
  background: white;
  transition: all 0.3s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8f9fa;
}

.menu-item.disabled {
  opacity: 0.5;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon-text {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 34rpx;
  font-weight: 500;
  color: #333;
}

.admin-badge {
  margin-left: 15rpx;
  padding: 4rpx 12rpx;
  background: #07C160;
  color: white;
  font-size: 22rpx;
  border-radius: 10rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: bold;
}

.info-section {
  margin: 20rpx;
}

.info-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.info-content {
  display: flex;
  flex-direction: column;
}

.info-content text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  line-height: 1.6;
}

.footer {
  padding: 40rpx;
  text-align: center;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}
