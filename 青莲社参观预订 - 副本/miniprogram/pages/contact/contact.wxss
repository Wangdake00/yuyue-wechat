/* pages/contact/contact.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 0;
}

/* 顶部标题 */
.header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  background: rgba(7, 193, 96, 0.9);
  color: white;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
}

/* 温馨提示 */
.tips {
  text-align: center;
  padding: 20rpx 40rpx;
  font-size: 26rpx;
  color: #666;
  background: rgba(255, 255, 255, 0.8);
  margin: 20rpx;
  border-radius: 15rpx;
  border-left: 6rpx solid #07C160;
}

.tips-text {
  display: block;
}

.tips-hint {
  display: block;
  color: #ff4d4f;
  font-size: 24rpx;
  margin-top: 10rpx;
  font-weight: bold;
}

/* 联系信息卡片 */
.contact-card {
  background: white;
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.header-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

.header-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 联系信息列表 */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  border-radius: 15rpx;
  background: #f8f9fa;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.contact-item:active {
  background: #f0f9f4;
  border-color: #07C160;
  transform: translateY(-2rpx);
}

.item-icon {
  width: 50rpx;
  height: 50rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-content {
  flex: 1;
}

.item-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.item-value {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.3;
}

.item-actions {
  display: flex;
  gap: 15rpx;
  margin-left: 20rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: none;
  min-width: 80rpx;
}

.call-btn {
  background: #52c41a;
  color: white;
}

.copy-btn {
  background: #1890ff;
  color: white;
}

.map-btn {
  background: #faad14;
  color: white;
}

/* 地图区域 */
.map-section {
  margin: 30rpx;
}

.map-container {
  height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

/* 办公时间 */
.office-hours {
  background: #fff7e6;
  border: 2rpx solid #ffd591;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-top: 30rpx;
}

.hours-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #d46b08;
  margin-bottom: 15rpx;
  text-align: center;
}

.hours-content {
  font-size: 28rpx;
  color: #d46b08;
  line-height: 1.5;
  text-align: center;
}

/* 管理入口弹窗 */
.admin-entry-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  padding: 30rpx;
}

.admin-entry-card {
  background: white;
  border-radius: 24rpx;
  padding: 50rpx 40rpx 40rpx;
  width: 90%;
  max-width: 600rpx;
  position: relative;
  text-align: center;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.admin-icon {
  font-size: 80rpx;
  color: #07C160;
  margin-bottom: 20rpx;
  display: block;
}

.admin-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.admin-subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.admin-actions {
  display: flex;
  gap: 20rpx;
}

.admin-cancel-btn, .admin-confirm-btn {
  flex: 1;
  padding: 25rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.admin-cancel-btn {
  background: #f8f9fa;
  color: #666;
  border: 2rpx solid #e0e0e0;
}

.admin-confirm-btn {
  background: #07C160;
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
}

.close-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f8f9fa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 36rpx;
  color: #999;
}

/* 底部信息 */
.footer {
  padding: 40rpx;
  text-align: center;
}

.footer-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .contact-card {
    margin: 20rpx;
    padding: 30rpx 25rpx;
  }
  
  .contact-item {
    padding: 20rpx;
  }
  
  .item-value {
    font-size: 30rpx;
  }
  
  .action-btn {
    padding: 10rpx 20rpx;
    font-size: 22rpx;
  }
}
