<!-- pages/booking/booking.wxml -->
<view class="container">
  <!-- 使用自定义背景图片 -->
  <image class="background-image" src="/images/小程序背景.jpeg" mode="aspectFill"></image>
  
  <view class="header">
    <text class="title">参观预订</text>
    <text class="subtitle">请填写参观信息</text>
  </view>

  <view class="form-section">
    <!-- 预约单位 -->
    <view class="form-item">
      <text class="label">预约单位</text>
      <picker mode="selector" range="{{schoolUnits}}" value="{{unitIndex}}" bindchange="onUnitChange">
        <view class="picker {{selectedUnit ? 'selected' : ''}}">
          {{selectedUnit ? selectedUnit : '请选择预约单位'}}
        </view>
      </picker>
    </view>
    
    <!-- 其他单位输入 -->
    <view class="form-item" wx:if="{{selectedUnit === '其他'}}">
      <text class="label">请填写单位名称</text>
      <input class="input" placeholder="请输入单位名称" value="{{otherUnit}}" bindinput="onOtherUnitInput" />
    </view>
    
    <!-- 活动开展内容 -->
    <view class="form-item">
      <text class="label">活动开展内容</text>
      <picker mode="selector" range="{{activityTypes}}" value="{{activityTypeIndex}}" bindchange="onActivityTypeChange">
        <view class="picker {{selectedActivityType ? 'selected' : ''}}">
          {{selectedActivityType ? selectedActivityType : '请选择活动类型'}}
        </view>
      </picker>
    </view>
    
    <!-- 其他活动类型输入 -->
    <view class="form-item" wx:if="{{selectedActivityType === '其他'}}">
      <text class="label">请填写活动内容</text>
      <input class="input" placeholder="请输入活动内容" value="{{otherActivity}}" bindinput="onOtherActivityInput" />
    </view>
    
    <!-- 选择日期 -->
    <view class="form-item">
      <text class="label">选择日期</text>
      <picker mode="date" value="{{selectedDate}}" start="{{minDate}}" end="{{maxDate}}" bindchange="onDateChange">
        <view class="picker {{selectedDate ? 'selected' : ''}}">
          {{selectedDate ? selectedDate : '请选择日期'}}
        </view>
      </picker>
    </view>
    
    <!-- 日期状态显示 -->
    <view class="date-status" wx:if="{{selectedDate}}">
      <view class="status-title">时段预约状态</view>
      <view class="time-slots-status">
        <view class="time-slot-card {{morningStatus}}">
          <view class="slot-info">
            <text class="time-text">上午</text>
            <text class="slot-status">{{morningStatus === 'available' ? '可预约' : '已预约'}}</text>
          </view>
          <text class="slot-icon">{{morningStatus === 'available' ? '可用' : '已约'}}</text>
        </view>
        <view class="time-slot-card {{afternoonStatus}}">
          <view class="slot-info">
            <text class="time-text">下午</text>
            <text class="slot-status">{{afternoonStatus === 'available' ? '可预约' : '已预约'}}</text>
          </view>
          <text class="slot-icon">{{afternoonStatus === 'available' ? '可用' : '已约'}}</text>
        </view>
      </view>
    </view>
    
    <!-- 选择时段 -->
    <view class="form-item">
      <text class="label">选择时段</text>
      <picker mode="selector" range="{{timePeriods}}" value="{{timePeriodIndex}}" bindchange="onTimePeriodChange">
        <view class="picker {{selectedTimePeriod ? 'selected' : ''}}">
          {{selectedTimePeriod ? selectedTimePeriod : '请选择时段'}}
        </view>
      </picker>
    </view>
    
    <!-- 开始时间 -->
    <view class="form-item" wx:if="{{selectedTimePeriod}}">
      <text class="label">开始时间</text>
      <picker mode="time" value="{{startTime}}" start="{{startTimeRange.start}}" end="{{startTimeRange.end}}" bindchange="onStartTimeChange">
        <view class="picker {{startTime ? 'selected' : ''}}">
          {{startTime ? startTime : '请选择开始时间'}}
        </view>
      </picker>
    </view>
    
    <!-- 结束时间 -->
    <view class="form-item" wx:if="{{selectedTimePeriod}}">
      <text class="label">预计结束时间</text>
      <picker mode="time" value="{{endTime}}" start="{{endTimeRange.start}}" end="{{endTimeRange.end}}" bindchange="onEndTimeChange">
        <view class="picker {{endTime ? 'selected' : ''}}">
          {{endTime ? endTime : '请选择结束时间'}}
        </view>
      </picker>
    </view>
    
    <!-- 是否需要讲解员 -->
    <view class="form-item switch-item">
      <text class="label">是否需要讲解员</text>
      <switch checked="{{needGuide}}" bindchange="onGuideChange" color="#07C160" />
    </view>
    
    <!-- 姓名 -->
    <view class="form-item">
      <text class="label">姓名</text>
      <input class="input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
    </view>
    
    <!-- 手机号 -->
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input {{phoneError ? 'error' : ''}}" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
      <text class="error-text" wx:if="{{phoneError}}">{{phoneError}}</text>
    </view>
    
    <!-- 参观人数 -->
    <view class="form-item">
      <text class="label">参观人数</text>
      <input class="input" type="number" placeholder="请输入参观人数" value="{{visitorCount}}" bindinput="onCountInput" />
    </view>
    
    <!-- 备注 -->
    <view class="form-item">
      <text class="label">备注信息</text>
      <textarea class="textarea" placeholder="请输入备注信息（选填）" value="{{notes}}" bindinput="onNotesInput" />
    </view>
  </view>
  
  <button class="submit-btn" bindtap="submitBooking" disabled="{{!isFormValid}}">
    {{isFormValid ? '提交预订' : '请填写完整信息'}}
  </button>
</view>
