/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  position: relative;
  padding-bottom: 100rpx;
}

/* 背景图片样式 */
.background-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  opacity: 0.15;
}

/* 顶部标题样式 */
.header-title {
  padding: 60rpx 40rpx 40rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(15px);
  position: relative;
  text-align: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
}

.title-text {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.5);
}

.subtitle-text {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1rpx 5rpx rgba(0, 0, 0, 0.3);
}

/* 社徽区域 */
.logo-section {
  background: rgba(255, 255, 255, 0.95);
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10px);
}

.shelian-logo {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  border: 4rpx solid #92e7bb;
}

.welcome-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.user-info {
  margin-top: 20rpx;
}

.user-greeting {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.auth-btn {
  background: #07C160;
  color: white;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  border: none;
  width: 100%;
}

.auth-btn:active {
  background: #06a050;
}

/* 信息区域 */
.info-section {
  background: rgba(255, 255, 255, 0.95);
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10px);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.section-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, #07C160, transparent);
}

/* 介绍内容 */
.intro-content {
  background: rgba(248, 249, 250, 0.8);
  padding: 30rpx;
  border-radius: 15rpx;
  border-left: 8rpx solid #07c17a;
}

.intro-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #555;
}

/* 须知内容 */
.notice-content {
  background: rgba(255, 249, 230, 0.8);
  padding: 30rpx;
  border-radius: 15rpx;
  border-left: 8rpx solid #faad14;
}

.notice-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.notice-item:last-child {
  margin-bottom: 0;
}

.notice-index {
  font-size: 28rpx;
  color: #faad14;
  font-weight: bold;
  margin-right: 15rpx;
  min-width: 40rpx;
}

.notice-text {
  font-size: 28rpx;
  line-height: 1.5;
  color: #666;
  flex: 1;
}

/* 底部信息 */
.footer {
  padding: 40rpx;
  text-align: center;
}

.footer-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1rpx 5rpx rgba(0, 0, 0, 0.9);
}

/* 确保内容在背景图片上可读 */
page {
  background: transparent;
}